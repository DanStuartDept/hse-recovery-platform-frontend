{
	"extends": "@repo/typescript-config/nextjs.json",
	"compilerOptions": {
		"paths": {
			"@/*": ["./src/*"]
		},
		"types": ["./cloudflare-env.d.ts", "node"]
	},
	"include": [
		"next-env.d.ts",
		"**/*.ts",
		"**/*.tsx",
		".next/types/**/*.ts",
		".next/dev/types/**/*.ts"
	],
	"exclude": ["node_modules"]
}
