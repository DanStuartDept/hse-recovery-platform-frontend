{
  "$schema": "https://biomejs.dev/schemas/2.4.9/schema.json",
  "root": false,
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "**",
      "!dist",
      "!build",
      "!coverage",
      "!docs",
      "!public"
    ]
  },
  "linter": {
    "enabled": true,
    "domains": {
      "react": "recommended"
    }
  }
}
