{
	"name": "@repo/vitest-config",
	"version": "0.0.0",
	"type": "module",
	"private": true,
	"description": "Shared Vitest configuration for the monorepo.",
	"files": [
		"dist"
	],
	"main": "./dist/es/index.js",
	"module": "./dist/es/index.js",
	"types": "./dist/es/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/es/index.d.ts",
				"default": "./dist/es/index.js"
			},
			"require": {
				"types": "./dist/cjs/index.d.cts",
				"default": "./dist/cjs/index.cjs"
			}
		},
		"./mocks": {
			"import": {
				"types": "./dist/es/mocks/index.d.ts",
				"default": "./dist/es/mocks/index.js"
			},
			"require": {
				"types": "./dist/cjs/mocks/index.d.cts",
				"default": "./dist/cjs/mocks/index.cjs"
			}
		}
	},
	"scripts": {
		"build": "bunchee",
		"dev": "bunchee --watch",
		"typecheck": "tsc --noEmit",
		"lint": "biome check --write"
	},
	"dependencies": {
		"@vitejs/plugin-react": "catalog:",
		"vite-tsconfig-paths": "catalog:"
	},
	"peerDependencies": {
		"vitest": "^1 || ^2 || ^3 || ^4",
		"@vitest/coverage-v8": "^1 || ^2 || ^3 || ^4",
		"jsdom": "^22 || ^23 || ^24 || ^26 || ^29",
		"vitest-sonar-reporter": "^2.0.4 || ^3.0.0"
	},
	"devDependencies": {
		"@repo/typescript-config": "workspace:*",
		"@repo/biome-config": "workspace:*",
		"@testing-library/jest-dom": "catalog:",
		"@vitest/coverage-v8": "catalog:",
		"bunchee": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:",
		"jsdom": "catalog:",
		"vitest-sonar-reporter": "catalog:"
	}
}
